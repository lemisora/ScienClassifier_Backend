# Environment variables for this Docker Compose project (it shall be modified)

###############################################################################
#  Do not include the oficial '.env' file to the repo, only this one
###############################################################################

# Some of these values are defaults, you might let them the way they are for development purposes

# ==========================================
# Configuración del Clúster (Spilo/Patroni)
# ==========================================
# Identificador único del clúster de base de datos
SCOPE=postgres_cluster

# ==========================================
# Almacén de Configuración Distribuida (DCS)
# ==========================================
# Host y puerto donde etcd está escuchando
ETCD3_HOST=etcd:2379
ETCD3_PORT=2379

# ==========================================
# Rutas y Persistencia
# ==========================================
# Directorio raíz dentro del contenedor
PGROOT=/home/postgres/pgdata/pgroot

# ==========================================
# Credenciales y Autenticación
# ==========================================
# Contraseña para el superusuario ('postgres' por defecto)
PGUSER_SUPERUSER=postgres
PGPASSWORD_SUPERUSER=postgres

# Credenciales para el usuario de replicación interna
PGUSER_STANDBY=standby
PGPASSWORD_STANDBY=standby_password_segura

# Credenciales para un usuario administrador de base de datos general
USE_ADMIN=true
PGUSER_ADMIN=admin
PGPASSWORD_ADMIN=admin_password_segura

# ==========================================
# Seguridad y Red
# ==========================================
# Permitir conexiones sin certificados SSL cifrados (desarrollo local)
ALLOW_NOSSL=true

# Puerto por defecto de PostgreSQL
PGPORT=5432

# ==========================================
# Localización
# ==========================================
# Codificación y configuración regional de la base de datos
INITDB_LOCALE=en_US.UTF-8

# ==========================================
# MinIO — almacenamiento de objetos
# ==========================================
# Usuario y contraseña root (mínimo 3 y 8 caracteres respectivamente)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Bucket donde se almacenan los PDFs
MINIO_BUCKET=scientific-papers

# ==========================================
# RabbitMQ — cola de mensajes
# ==========================================
# Cookie compartida entre los 3 nodos del cluster (debe ser idéntica en todos)
RABBITMQ_ERLANG_COOKIE=pda-rabbit-secret-cookie

# Credenciales del usuario por defecto
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_password_segura

# ==========================================
# FastAPI / JWT
# ==========================================
# Clave secreta para firmar los tokens JWT (cambiar en producción)
JWT_SECRET_KEY=cambia_esto_en_produccion

# ==========================================
# Docker — registro de imágenes
# ==========================================
# Prefijo del registro donde se publican las imágenes de FastAPI y Worker.
# Ejemplos: usuario de Docker Hub, IP de registro local (192.168.x.x:5000)
REGISTRY=localhost