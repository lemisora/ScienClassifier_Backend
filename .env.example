# Variables de entorno para el Docker Stack (modificar antes de desplegar)
###############################################################################
#  NO incluir el archivo '.env' real en el repo, solo este .env.example
###############################################################################

# ==========================================
# Docker Swarm
# ==========================================
# IP de esta máquina (usada por just init-swarm y etcd)
MANAGER_IP=192.168.1.10
# Los siguientes tokens se llenan automáticamente con: just init-swarm
SWARM_WORKER_TOKEN=
SWARM_MANAGER_TOKEN=

# Hostnames exactos de cada máquina del cluster (ver: docker node ls)
# Cada servicio con estado (etcd, patroni, minio, rabbitmq) se ancla a un nodo
NODE1_HOSTNAME=node1
NODE2_HOSTNAME=node2
NODE3_HOSTNAME=node3

# ==========================================
# etcd — almacén de configuración distribuida
# ==========================================
ETCD3_PORT=2379
ETCD3_PEER_PORT=2380
# Token que identifica el cluster (igual en todos los nodos)
ETCD3_CLUSTER_TOKEN=scienclassifier-etcd-token
# Lista de todos los nodos etcd: nombre=http://IP:peer_port,...
# Ejemplo: etcd-node1=http://192.168.1.10:2380,etcd-node2=http://192.168.1.11:2380,...
ETCD3_INITIAL_CLUSTER=etcd-node1=http://192.168.1.10:2380,etcd-node2=http://192.168.1.11:2380,etcd-node3=http://192.168.1.12:2380

# ==========================================
# Patroni + PostgreSQL
# ==========================================
SCOPE=postgres_cluster
PGROOT=/home/postgres/pgdata/pgroot
PGPORT=5432
ALLOW_NOSSL=true
INITDB_LOCALE=en_US

# Superusuario de PostgreSQL
PGUSER_SUPERUSER=postgres
PGPASSWORD_SUPERUSER=postgres

# Usuario de replicación interna
PGUSER_STANDBY=standby
PGPASSWORD_STANDBY=replica

# Usuario administrador de la base de datos
USE_ADMIN=true
PGUSER_ADMIN=admin
PGPASSWORD_ADMIN=lofi_admin

# ==========================================
# MinIO — almacenamiento de objetos
# ==========================================
# Mínimo 3 chars para usuario, 8 para contraseña
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Bucket donde se almacenan los PDFs
MINIO_BUCKET=scientific-papers

# ==========================================
# RabbitMQ — cola de mensajes
# ==========================================
# Cookie erlang: debe ser IDÉNTICA en los 3 nodos
RABBITMQ_ERLANG_COOKIE=scienclassifier-rabbit-cookie
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_password_segura

# ==========================================
# FastAPI / JWT
# ==========================================
# Cambiar por una clave aleatoria segura en producción
JWT_SECRET_KEY=cambia_esto_en_produccion

# ==========================================
# Docker — registro de imágenes
# ==========================================
# Usuario de Docker Hub o IP de registro local (ej: 192.168.1.10:5000)
REGISTRY=localhost
