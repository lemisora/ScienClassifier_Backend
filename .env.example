# Environment variables for this Docker Stack project (it shall be modified)
###############################################################################
#  Do not include the oficial '.env' file to the repo, only this one
###############################################################################
# Some of these values are defaults, you might let them the way they are for development purposes

# ==========================================
# Configuración del Clúster (Spilo/Patroni)
# ==========================================
# Identificador único del clúster de base de datos
SCOPE=postgres_cluster

# ==========================================
# Almacén de Configuración Distribuida (DCS)
# ==========================================
# Puerto cliente de etcd
ETCD3_PORT=2379
# Puerto de sincronización entre nodos etcd (peer)
ETCD3_PEER_PORT=2380
# Token único que identifica el cluster de etcd (cámbialo en producción)
ETCD3_CLUSTER_TOKEN=scienclassifier-etcd-token
ETCD_NODE_NAME=etcd_name
ETCD_NODE_IP=192.168.1.10

# ==========================================
# Rutas y Persistencia
# ==========================================
# Directorio raíz dentro del contenedor
PGROOT=/home/postgres/pgdata/pgroot

# ==========================================
# Credenciales y Autenticación
# ==========================================
# Contraseña para el superusuario ('postgres' por defecto)
PGUSER_SUPERUSER=postgres
PGPASSWORD_SUPERUSER=postgres
# Credenciales para el usuario de replicación interna
PGUSER_STANDBY=standby
PGPASSWORD_STANDBY=replica
# Credenciales para un usuario administrador de base de datos general
USE_ADMIN=true
PGUSER_ADMIN=admin
PGPASSWORD_ADMIN=lofi_admin

# ==========================================
# Seguridad y Red
# ==========================================
# Permitir conexiones sin certificados SSL cifrados (desarrollo local)
ALLOW_NOSSL=true
# Puerto por defecto de PostgreSQL
PGPORT=5432

# ==========================================
# Localización
# ==========================================
# Codificación y configuración regional de la base de datos
INITDB_LOCALE=en_US.UTF-8

# ==========================================
# Docker Swarm
# ==========================================
# IP de la máquina manager principal
MANAGER_IP=192.168.1.10
# Los siguientes tokens se llenan automáticamente con: just init-swarm
SWARM_WORKER_TOKEN=
SWARM_MANAGER_TOKEN=
